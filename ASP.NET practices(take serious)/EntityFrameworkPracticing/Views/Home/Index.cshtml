@model IEnumerable<Guy>
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">@ViewData["AnyResult"]</h1>
    <p>@ViewData["AnyResult"]<a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
<table class="table table-striped table-dark">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">First</th>
            <th scope="col">Mid</th>
            <th scope="col">Last</th>
        </tr>
    </thead>
    <tbody>
      
        @foreach (var item in @Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.IsRemoved</td>
            </tr>
            
        }
    </tbody>
</table>
